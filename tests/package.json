{
  "name": "uno-tests",
  "version": "1.0.0",
  "description": "Tests for UNO multiplayer game",
  "scripts": {
    "test": "jest --runInBand",
    "test:unit": "jest tests/unit",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "jest": "^29.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/*.test.js"],
    "moduleNameMapper": {
      "^../shared/(.*)$": "<rootDir>/../backend/shared/$1"
    }
  }
}
